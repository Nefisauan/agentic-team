# Server
PORT=3001
NODE_ENV=development

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis / Upstash
REDIS_URL=redis://:[PASSWORD]@[HOST].upstash.io:6379

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=outreach@revenueprosystems.com
SENDGRID_INBOUND_WEBHOOK_SECRET=your-webhook-secret

# Twilio (optional SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Google Calendar
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=...
GOOGLE_CALENDAR_ID=primary

# Calendly (fallback if Google Calendar not set up — recommended to start)
CALENDLY_LINK=https://calendly.com/revenueprosystems/20min

# Pipeline config
QUALIFICATION_SCORE_THRESHOLD=60
FOLLOWUP_DELAY_DAYS=3
ANALYTICS_CRON_SCHEDULE=0 8 * * *

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
